# INSIGHT FOOTBALL environment template
# Copy to .env for local development. Do not commit real values.

# LLM providers
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Football and news data providers
APP_FOOTBALL_API_KEY=
NEWS_API_KEY=
GNEWS_API_KEY=

# Rendering providers
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_ID=
RENDER_API_KEY=

# YouTube publishing
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Facebook publishing
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Telegram publishing
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Runtime controls
INSIGHT_FOOTBALL_ENV=development
INSIGHT_FOOTBALL_DRY_RUN=true
INSIGHT_FOOTBALL_REQUIRE_HUMAN_APPROVAL=true

