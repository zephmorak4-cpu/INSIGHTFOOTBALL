{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "EditorialValidatorInputPackage",
  "type": "object",
  "required": [
    "metadata",
    "match",
    "competition",
    "story_angle",
    "central_question",
    "surprising_fact",
    "primary_evidence",
    "contradictory_evidence",
    "insight_summary",
    "match_edge",
    "confidence_scores",
    "locked_fields",
    "agent_outputs"
  ],
  "properties": {
    "metadata": { "type": "object", "required": ["production_id", "package_version"] },
    "match": { "type": "object" },
    "competition": { "type": "string", "minLength": 1 },
    "story_angle": { "type": "string", "minLength": 1 },
    "central_question": { "type": "string", "minLength": 1 },
    "surprising_fact": { "type": "string", "minLength": 1 },
    "primary_evidence": { "type": "array", "minItems": 1 },
    "secondary_evidence": { "type": "array" },
    "contradictory_evidence": { "type": "array" },
    "insight_summary": { "type": "string", "minLength": 1 },
    "match_edge": { "type": "string", "minLength": 1 },
    "confidence_scores": { "type": "object" },
    "locked_fields": { "type": "object" },
    "agent_outputs": { "type": "object" }
  }
}
