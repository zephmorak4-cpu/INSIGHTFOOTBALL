{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "InsightFootballMatchSelectionForEvidenceFilter",
  "title": "InsightFootballMatchSelectionForEvidenceFilter",
  "type": "object",
  "required": [
    "agent_id",
    "production_id",
    "selected_match",
    "approval_status",
    "next_agent"
  ],
  "properties": {
    "agent_id": { "type": "string", "enum": ["IF-A01"] },
    "production_id": { "type": "string", "minLength": 1 },
    "selected_match": {
      "type": "object",
      "required": ["home_team", "away_team", "competition", "kickoff_time", "country"]
    },
    "approval_status": { "type": "string", "enum": ["approved"] },
    "next_agent": { "type": "string", "enum": ["IF-A02"] }
  }
}
