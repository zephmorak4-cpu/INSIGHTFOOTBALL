{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "InsightFootballStoryHunterForInsightEngine",
  "type": "object",
  "required": [
    "production_id",
    "agent_id",
    "selected_match",
    "story_angle",
    "central_question",
    "surprising_fact",
    "locked_fields",
    "approval_status",
    "next_agent"
  ],
  "properties": {
    "production_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "enum": ["IF-A02"] },
    "selected_match": { "type": "object" },
    "story_angle": { "type": "string", "minLength": 1 },
    "central_question": { "type": "string", "minLength": 1 },
    "surprising_fact": { "type": "string", "minLength": 1 },
    "locked_fields": { "type": "object" },
    "approval_status": { "type": "string", "enum": ["approved"] },
    "next_agent": { "type": "string", "enum": ["IF-A03"] }
  }
}
