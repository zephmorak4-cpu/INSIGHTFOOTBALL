{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "InsightFootballMatchSelectorDailyInput",
  "title": "InsightFootballMatchSelectorDailyInput",
  "type": "object",
  "required": ["production_metadata", "fixtures"],
  "properties": {
    "production_metadata": {
      "type": "object",
      "required": ["date", "production_id"],
      "properties": {
        "date": { "type": "string", "minLength": 1 },
        "production_id": { "type": "string", "minLength": 1 },
        "language": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "home_team",
          "away_team",
          "competition",
          "kickoff_time",
          "country",
          "audience_interest",
          "importance",
          "rivalry",
          "available_data",
          "story_potential"
        ],
        "properties": {
          "home_team": { "type": "string", "minLength": 1 },
          "away_team": { "type": "string", "minLength": 1 },
          "competition": { "type": "string", "minLength": 1 },
          "kickoff_time": { "type": "string", "minLength": 1 },
          "country": { "type": "string", "minLength": 1 },
          "audience_interest": { "type": "number", "minimum": 0, "maximum": 10 },
          "importance": { "type": "number", "minimum": 0, "maximum": 10 },
          "rivalry": { "type": "number", "minimum": 0, "maximum": 10 },
          "available_data": { "type": "number", "minimum": 0, "maximum": 10 },
          "story_potential": { "type": "number", "minimum": 0, "maximum": 10 }
        }
      }
    },
    "audience_notes": { "type": "object" },
    "priority_competitions": { "type": "array" },
    "data_availability_notes": { "type": "object" },
    "match_context": { "type": "object" }
  }
}
