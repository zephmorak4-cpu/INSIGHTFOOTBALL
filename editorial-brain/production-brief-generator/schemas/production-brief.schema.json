{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "InsightFootballProductionBrief",
  "type": "object",
  "required": [
    "production_id",
    "brief_id",
    "timestamp",
    "match",
    "competition",
    "video_type",
    "target_duration_seconds",
    "target_platforms",
    "language",
    "brand_opening",
    "central_question",
    "hook_direction",
    "surprising_fact",
    "story_angle",
    "main_insight",
    "evidence_to_use",
    "evidence_to_avoid",
    "contradiction_to_handle",
    "match_edge",
    "key_advantage",
    "x_factor",
    "viewer_takeaway",
    "desired_emotion",
    "tone_rules",
    "forbidden_phrases",
    "required_phrases",
    "cta_direction",
    "scriptwriter_notes",
    "locked_fields",
    "next_agent"
  ],
  "properties": {
    "production_id": { "type": "string", "minLength": 1 },
    "brand_opening": { "type": "string", "minLength": 1 },
    "target_duration_seconds": { "type": "integer" },
    "target_platforms": { "type": "array", "minItems": 1 },
    "evidence_to_use": { "type": "array", "minItems": 1 },
    "forbidden_phrases": { "type": "array", "minItems": 1 },
    "required_phrases": { "type": "array", "minItems": 1 },
    "next_agent": { "type": "string", "enum": ["IF-A05"] }
  }
}
