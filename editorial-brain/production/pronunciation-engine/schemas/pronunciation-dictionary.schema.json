{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "INSIGHT FOOTBALL Pronunciation Dictionary",
  "type": "object",
  "required": ["production_id", "component_id", "items", "approval_status"],
  "properties": {
    "production_id": {"type": "string"},
    "component_id": {"const": "IF-V02"},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["term", "phonetic", "language", "notes"]
      }
    },
    "approval_status": {"enum": ["approved", "blocked"]}
  }
}
