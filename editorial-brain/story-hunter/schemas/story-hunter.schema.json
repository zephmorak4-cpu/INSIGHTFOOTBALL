{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "InsightFootballStoryHunterOutput",
  "title": "InsightFootballStoryHunterOutput",
  "type": "object",
  "required": [
    "production_id",
    "agent_id",
    "agent_name",
    "prompt_id",
    "prompt_version",
    "input_version",
    "output_version",
    "timestamp",
    "selected_match",
    "story_angle",
    "central_question",
    "surprising_fact",
    "why_this_matters",
    "why_fans_should_care",
    "supporting_context",
    "rejected_angles",
    "story_confidence",
    "warnings",
    "human_review_flags",
    "locked_fields",
    "approval_status",
    "next_agent"
  ],
  "properties": {
    "production_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "enum": ["IF-A02"] },
    "agent_name": { "type": "string", "minLength": 1 },
    "prompt_id": { "type": "string", "enum": ["IF-PROMPT-02-STORY-HUNTER"] },
    "prompt_version": { "type": "string", "enum": ["v1.0"] },
    "input_version": { "type": "string", "minLength": 1 },
    "output_version": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "selected_match": {
      "type": "object",
      "required": ["home_team", "away_team", "competition", "kickoff_time", "country"]
    },
    "story_angle": { "type": "string", "minLength": 1 },
    "central_question": { "type": "string", "minLength": 1 },
    "surprising_fact": { "type": "string", "minLength": 1 },
    "why_this_matters": { "type": "string", "minLength": 1 },
    "why_fans_should_care": { "type": "string", "minLength": 1 },
    "supporting_context": { "type": "array", "minItems": 1 },
    "rejected_angles": { "type": "array" },
    "story_confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "warnings": { "type": "array" },
    "human_review_flags": { "type": "array" },
    "locked_fields": {
      "type": "object",
      "required": ["story_angle", "central_question", "surprising_fact"],
      "properties": {
        "story_angle": { "type": "string", "minLength": 1 },
        "central_question": { "type": "string", "minLength": 1 },
        "surprising_fact": { "type": "string", "minLength": 1 }
      }
    },
    "approval_status": { "type": "string", "enum": ["approved", "needs_revision", "rejected", "blocked", "human_review_required"] },
    "next_agent": { "type": "string", "enum": ["IF-A03"] }
  }
}
