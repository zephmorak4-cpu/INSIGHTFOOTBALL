{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "InsightFootballProductionPackage",
  "title": "InsightFootballProductionPackage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_id",
    "date",
    "match",
    "competition",
    "selected_reason",
    "story_angle",
    "surprising_fact",
    "central_question",
    "evidence_points",
    "insight_dashboard",
    "final_script",
    "storyboard",
    "visual_direction",
    "captions",
    "publishing_metadata",
    "quality_control",
    "status"
  ],
  "properties": {
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home_team", "away_team", "kickoff_time"],
      "properties": {
        "home_team": { "type": "string", "minLength": 1 },
        "away_team": { "type": "string", "minLength": 1 },
        "kickoff_time": { "type": "string", "minLength": 1 },
        "venue": { "type": "string" }
      }
    },
    "competition": {
      "type": "string",
      "minLength": 1
    },
    "selected_reason": {
      "type": "string",
      "minLength": 1
    },
    "story_angle": {
      "type": "string",
      "minLength": 1
    },
    "surprising_fact": {
      "type": "string",
      "minLength": 1
    },
    "central_question": {
      "type": "string",
      "minLength": 1
    },
    "evidence_points": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["point", "why_it_matters", "source_type", "confidence"],
        "properties": {
          "point": { "type": "string", "minLength": 1 },
          "why_it_matters": { "type": "string", "minLength": 1 },
          "source_type": { "type": "string", "minLength": 1 },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    },
    "insight_dashboard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "home_win_probability",
        "draw_probability",
        "away_win_probability",
        "form_summary",
        "tactical_advantage",
        "uncertainty_level",
        "x_factor",
        "surprising_detail",
        "plain_english_summary"
      ],
      "properties": {
        "home_win_probability": { "type": "integer", "minimum": 0, "maximum": 100 },
        "draw_probability": { "type": "integer", "minimum": 0, "maximum": 100 },
        "away_win_probability": { "type": "integer", "minimum": 0, "maximum": 100 },
        "form_summary": { "type": "string", "minLength": 1 },
        "tactical_advantage": { "type": "string", "minLength": 1 },
        "uncertainty_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "x_factor": { "type": "string", "minLength": 1 },
        "surprising_detail": { "type": "string", "minLength": 1 },
        "plain_english_summary": { "type": "string", "minLength": 1 }
      }
    },
    "final_script": {
      "type": "object",
      "additionalProperties": false,
      "required": ["voiceover", "word_count", "estimated_duration_seconds"],
      "properties": {
        "voiceover": { "type": "string", "minLength": 1 },
        "word_count": { "type": "integer", "minimum": 1, "maximum": 150 },
        "estimated_duration_seconds": { "type": "integer", "minimum": 1, "maximum": 60 },
        "hook": { "type": "string" },
        "closing_engagement_question": { "type": "string" }
      }
    },
    "storyboard": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scene_number",
          "timestamp_start",
          "timestamp_end",
          "voiceover_line",
          "visual_description",
          "on_screen_text",
          "animation_instruction",
          "asset_needed",
          "caption_text"
        ],
        "properties": {
          "scene_number": { "type": "integer", "minimum": 1 },
          "timestamp_start": { "type": "number", "minimum": 0 },
          "timestamp_end": { "type": "number", "minimum": 0, "maximum": 60 },
          "voiceover_line": { "type": "string" },
          "visual_description": { "type": "string" },
          "on_screen_text": { "type": "string" },
          "animation_instruction": { "type": "string" },
          "asset_needed": {
            "type": "array",
            "items": { "type": "string" }
          },
          "caption_text": { "type": "string" }
        }
      }
    },
    "visual_direction": {
      "type": "object",
      "additionalProperties": true
    },
    "captions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["start", "end", "text"],
        "properties": {
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0, "maximum": 60 },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },
    "publishing_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["youtube_title", "facebook_caption", "telegram_caption", "hashtags"],
      "properties": {
        "youtube_title": { "type": "string", "minLength": 1 },
        "facebook_caption": { "type": "string", "minLength": 1 },
        "telegram_caption": { "type": "string", "minLength": 1 },
        "hashtags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "quality_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pass_or_fail",
        "reason",
        "issues_found",
        "required_fixes",
        "retention_score",
        "clarity_score",
        "story_score",
        "evidence_score",
        "final_recommendation"
      ],
      "properties": {
        "pass_or_fail": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "reason": { "type": "string" },
        "issues_found": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_fixes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "retention_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "clarity_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "story_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "evidence_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "final_recommendation": { "type": "string" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "needs_review", "approved", "rendered", "published", "failed"]
    }
  }
}
